# ═══════════════════════════════════════════════════════
#  GenoVault — Root .gitignore
#  Covers: all three sub-projects (backend, blockchain, frontend)
# ═══════════════════════════════════════════════════════

# ── Node.js ─────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
*.log
logs/

# ── Environment / Secrets ────────────────────────────────
# NEVER commit private keys or API keys
.env
.env.local
.env.development
.env.production
.env.staging
.env.test

# ── OS Files ─────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Editor / IDE ─────────────────────────────────────────
.vscode/
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.swp
.vs/

# ── Build Output ─────────────────────────────────────────
dist/
dist-ssr/
build/
out/
*.js.map

# ── Uploads (files should live in Azure, not git) ────────
uploads/

# ── Test Coverage ────────────────────────────────────────
coverage/
.nyc_output/

# ── Temp / Cache ─────────────────────────────────────────
.cache/
tmp/
temp/

# ══════════════════════════════════════════════════════════
#  BLOCKCHAIN (Hardhat) — auto-generated, never commit
# ══════════════════════════════════════════════════════════
blockchain/artifacts/
blockchain/cache/
blockchain/node_modules/

# ══════════════════════════════════════════════════════════
#  FRONTEND (Vite/React) — build output
# ══════════════════════════════════════════════════════════
frontend/dist/
frontend/node_modules/

# ══════════════════════════════════════════════════════════
#  BACKEND — runtime & secrets
# ══════════════════════════════════════════════════════════
backend/node_modules/
backend/dist/
backend/uploads/
