# ═══════════════════════════════════════════════════════
#  backend/.gitignore
# ═══════════════════════════════════════════════════════

# ── Node.js ─────────────────────────────────────────────
node_modules/
dist/

# ── Environment / Secrets (NEVER commit) ────────────────
.env
.env.local
.env.production
.env.staging
.env.test

# ── Logs ─────────────────────────────────────────────────
*.log
logs/
npm-debug.log*

# ── Uploads (files go to Azure, not git) ────────────────
uploads/

# ── Build artifacts ──────────────────────────────────────
*.js.map
build/
coverage/
.nyc_output/

# ── OS ───────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── Temp / Cache ─────────────────────────────────────────
tmp/
.cache/
