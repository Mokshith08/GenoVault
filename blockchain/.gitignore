# ═══════════════════════════════════════════════════════
#  blockchain/.gitignore
#  Hardhat auto-generated files — never needed in git
# ═══════════════════════════════════════════════════════

# ── Hardhat compile output (auto-regenerated by: npx hardhat compile) ──
artifacts/
cache/

# ── Dependencies ─────────────────────────────────────────
node_modules/

# ── Logs ─────────────────────────────────────────────────
*.log
logs/

# ── Environment ──────────────────────────────────────────
.env
.env.local

# ── OS ───────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ──────────────────────────────────────────────────────────
# What IS committed (source of truth):
#   contracts/       ← Solidity source code ✅
#   scripts/         ← deploy scripts ✅
#   deployments/     ← contract addresses + ABI ✅
#   hardhat.config.js ← network config ✅
#   package.json     ← dependencies ✅
# ──────────────────────────────────────────────────────────
