# ═══════════════════════════════════════════════════════
#  frontend/.gitignore
# ═══════════════════════════════════════════════════════

# ── Node.js ─────────────────────────────────────────────
node_modules/

# ── Build output (Vite) ──────────────────────────────────
dist/
dist-ssr/

# ── Environment / Secrets ────────────────────────────────
.env
.env.local
.env.development
.env.production
.env.staging
*.local

# ── Logs ─────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ── Test / Coverage ──────────────────────────────────────
coverage/

# ── Editor / IDE ─────────────────────────────────────────
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
Thumbs.db
